{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ticketing-system-client": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@ngx-env/builder:application",
          "options": {
            "outputPath": "dist/ticketing-system-client",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "development": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ],
              "optimization": false,
              "sourceMap": false,
              "namedChunks": false
            },
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "optimization": true,
              "sourceMap": false,
              "namedChunks": false
            }
          }
        },
        "serve": {
          "builder": "@ngx-env/builder:dev-server",
          "configurations": {
            "development": {
              "buildTarget": "ticketing-system-client:build:development"
            },
            "production": {
              "buildTarget": "ticketing-system-client:build:production"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "prebundle": false
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "ff3e8121-6a9d-42ba-a923-3c718a515e0c"
  }
}